diff --git a/solution/cuda/kernel.cu b/solution/cuda/kernel.cu
index 3ba3257..bcb1fd3 100644
--- a/solution/cuda/kernel.cu
+++ b/solution/cuda/kernel.cu
@@ -58,6 +58,11 @@ __global__ void __launch_bounds__(BLOCK_SIZE, 9) gdn_decode_kernel(
     constexpr int SPLIT_FACTOR = HEAD_DIM / ROWS_PER_BLOCK;
     constexpr int HEADS_X_SPLIT = NUM_V_HEADS * SPLIT_FACTOR;
 
+    __builtin_assume(blockDim.x == BLOCK_SIZE);
+    __builtin_assume(threadIdx.x < BLOCK_SIZE);
+    __builtin_assume(gridDim.y == 1);
+    __builtin_assume(gridDim.z == 1);
+
     const int idx = blockIdx.x;
     const int batch = idx / HEADS_X_SPLIT;
     const int remainder = idx - batch * HEADS_X_SPLIT;
@@ -68,18 +73,17 @@ __global__ void __launch_bounds__(BLOCK_SIZE, 9) gdn_decode_kernel(
     const int warp_id = tid >> 5;
     const int lane = tid & 31;
 
-    float g, beta, beta_g;
+    float g, beta;
     if (lane == 0) {
         float a_val = __bfloat162float(a[batch * NUM_V_HEADS + vh]);
         float dt_val = dt_bias[vh];
         float A_val = A_log[vh];
         g = expf(-expf(A_val) * softplus(a_val + dt_val));
         beta = 1.0f / (1.0f + expf(-__bfloat162float(b_gate[batch * NUM_V_HEADS + vh])));
-        beta_g = beta * g;
     }
     g = __shfl_sync(0xffffffff, g, 0);
     beta = __shfl_sync(0xffffffff, beta, 0);
-    beta_g = __shfl_sync(0xffffffff, beta_g, 0);
+    float beta_g = beta * g;
 
     const int k_base = batch * NUM_K_HEADS * HEAD_DIM + qkh * HEAD_DIM + (lane << 2);
     float k_vals[4];
